# Discord application — required
DISCORD_TOKEN=

# Slash command deploy (guild)
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

# Command deploy scope: guild | global | both
#   guild  = only DISCORD_GUILD_ID (instant, dev)
#   global = every server (~1h first propagation)
#   both   = instant on dev guild + global everywhere (dev guild shows duplicates)
# Default when unset: guild if DISCORD_GUILD_ID is set, otherwise global.
DEPLOY_SCOPE=

# Website API — localhost is rewritten to host.docker.internal inside Docker (see apiService.ts).
API_BASE_URL=http://localhost:3000/api
# Production:
# API_BASE_URL=https://www.example.com/api

# Same secret as Vercel BOT_SERVICE_API_KEY when BOT_SERVICE_SPOTS_PROTECT=true.
API_KEY=

# Health HTTP server — Docker wget + Vercel admin probe use Bearer auth.
# Match Vercel DISCORD_BOT_HEALTH_SECRET to this value (same string as BOT_HEALTH_SECRET on the bot host).
BOT_HEALTH_PORT=3589
BOT_HEALTH_SECRET=

# Portal-to-bot actions — separate Bearer secret for forum refresh jobs.
# Generate a strong random value and match DISCORD_BOT_PORTAL_SECRET in the portal.
BOT_PORTAL_SECRET=

# Optional local-only: GET /health without Bearer (never on public hosts).
# BOT_HEALTH_SKIP_AUTH=true

# Supabase portal sync — lets the web portal see online status, installed
# servers, and channel bindings. Use the SERVICE ROLE (secret) key, NOT the
# anon key: Supabase dashboard → Project Settings → API → service_role.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare Tunnel — never commit a live token.
# If a token is exposed, rotate it in Cloudflare before placing the replacement here.
# Start with: docker compose --profile tunnel up -d
CLOUDFLARE_TUNNEL_TOKEN=
